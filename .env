# Environment Config

# store your secrets and config variables in here
# reference these in your code with process.env.SECRET

# note: .env is a shell file so there can't be spaces around =

# Put your Discord bot token here to jumpstart the bot
DISCORD_BOT_TOKEN=DISCORD_BOT_TOKEN

# Put your Discord bot's owner's user ID here (for owner-only commands)
OWNER_ID=DISCORD_USER_ID

# Put your Discord bot's client ID and the guild ID of your server here (for registering slash commands)
CLIENT_ID=DISCORD_BOT_ID
GUILD_ID=DISCORD_SERVER_ID

# Used for AI chat, put your Google AI Studio API key here
GOOGLE_AI_STUDIO_API_KEY=GOOGLE_AI_STUDIO_API_KEY